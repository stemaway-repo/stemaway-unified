                    <div class="dk-signal-metric">
                      <span class="dk-signal-dim">Prioritization</span>
                      <span class="dk-signal-score">3/5</span>
                    </div>
                    <div class="dk-signal-bar">
                      <div class="dk-signal-bar-fill dk-signal-bar-fill--amber" style="width: 60%"></div>
                    </div>
                  </div>
                  <div class="dk-signal-card dk-signal-card--green" data-signal="q2">
                    <div class="dk-signal-accent dk-signal-accent--green"></div>
                    <div class="dk-signal-header">
                      <div class="dk-signal-icon dk-signal-icon--green">✓</div>
                      <span class="dk-signal-title dk-signal-title--green">Strength to probe</span>
                    </div>
                    <div class="dk-signal-metric">
                      <span class="dk-signal-dim">Tradeoff analysis</span>
                      <span class="dk-signal-score">5/5</span>
                    </div>
                    <div class="dk-signal-bar">
                      <div class="dk-signal-bar-fill dk-signal-bar-fill--green" style="width: 100%"></div>
                    </div>
                  </div>
                </div>

                <!-- Connection lines from signals to questions -->
                <svg class="dk-blueprint-connectors" viewBox="0 0 100 40" preserveAspectRatio="none">
                  <path d="M 25,0 Q 25,20 10,40" stroke="#d4a017" stroke-width="0.3" stroke-dasharray="1 1" fill="none"
