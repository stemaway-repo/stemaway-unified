                            <span class="dk-dim-more">+ 4 more</span>
                          </div>
                          <div class="dk-ci-dim-row">
                            <span class="dk-ci-dim-type">Wildcard</span>
                            <span class="dk-ci-mono">Cache invalidation</span>
                            <span class="dk-ci-mono">Memory pressure</span>
