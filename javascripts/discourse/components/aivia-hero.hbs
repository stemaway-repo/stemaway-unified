                            stroke-width="2">
                            <path d="M6 9l6 6 6-6" />
                          </svg>
                        </div>
                        <div class="dk-ci-expand">
                          <div class="dk-ci-dim-row">
                            <span class="dk-ci-dim-type">Fixed</span>
                            <span class="dk-tag dk-tag--green dk-tag--sm">Tradeoff analysis</span>
