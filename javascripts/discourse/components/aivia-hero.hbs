                </div>
                <p class="dk-panel-sub">Auto-generated from prescreening evaluation data</p>

                <!-- Evaluation context pill -->
                <div class="dk-eval-pill-wrap">
                  <div class="dk-eval-pill">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path
                        d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                    </svg>
                    <span class="dk-eval-pill-label">Evaluation</span>
                    <span class="dk-eval-pill-name">KV cache manager</span>
