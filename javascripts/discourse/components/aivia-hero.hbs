                </div>

                <!-- Signal cards (2) -->
                <div class="dk-signal-grid dk-signal-grid--three">
                  <div class="dk-signal-card dk-signal-card--amber" data-signal="q1">
                    <div class="dk-signal-accent dk-signal-accent--amber"></div>
                    <div class="dk-signal-header">
                      <div class="dk-signal-icon dk-signal-icon--amber">!</div>
                      <span class="dk-signal-title dk-signal-title--amber">Gap identified</span>
